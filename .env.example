# ─────────────────────────────────────────────────────────────────────────────
# Dev Container — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Image / build ─────────────────────────────────────────────────────────────
BASE_IMAGE=ubuntu:24.04
# GH_VERSION=2.63.0
# TERRAFORM_VERSION=1.9.0

# ── Container identity ─────────────────────────────────────────────────────────
CONTAINER_NAME=dev-container
CONTAINER_HOSTNAME=dev-container
WANTED_UID=1000
WANTED_GID=1000
USERNAME=dev

# ── Volumes (host paths) ───────────────────────────────────────────────────────
# Persistent browser profile — keeps logins/sessions across container rebuilds
BROWSER_PROFILE_DIR=./browser-profile
# Your home dir mapped into container
HOME_DIR=~/dev-home
# Project workspace
WORKSPACE_DIR=./workspace

# ── Tailscale ──────────────────────────────────────────────────────────────────
# Auth key: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=dev-container

# ── GH token (multi-user) ──────────────────────────────────────────────────────
# Pass any GH personal access token — works for github.com and GHE.
# In CI (GitHub Actions): use secrets.GITHUB_TOKEN or a fine-grained PAT.
# At runtime: docker compose run -e GH_TOKEN=ghp_xxx dev gh auth status
GH_TOKEN=
# Fallback (also respected by gh cli)
GITHUB_TOKEN=

# ── SSH ────────────────────────────────────────────────────────────────────────
SSH_AUTHORIZED_KEYS=
DEV_PASSWORD=
SSH_PORT=2222

# ── Browser / VNC ───────────────────────────────────────────────────────────────
CDP_PORT=9222
VNC_PORT=5900
NOVNC_PORT=6080
BROWSER_RESOLUTION=1920x1080

# ── Locale ──────────────────────────────────────────────────────────────────────
TZ=America/New_York

# ── Docker ──────────────────────────────────────────────────────────────────────
RESTART_POLICY=unless-stopped
NETWORK_NAME=dev-net
